# ── Trello ──────────────────────────────────────────────────────────────────
# Get these from https://trello.com/app-key
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_BOARD_ID=your_board_id_here

# Webhook secret — any random string you choose (generate with: openssl rand -hex 32)
TRELLO_WEBHOOK_SECRET=your_webhook_secret_here

# Your deployed server URL (use ngrok URL for local dev)
TRELLO_WEBHOOK_CALLBACK_URL=https://your-app.netlify.app/webhook/trello

# Trello List IDs — get these by adding .json to your board URL
# Example: https://trello.com/b/BOARD_ID.json
TRELLO_LIST_READY_TO_BUILD=list_id_here
TRELLO_LIST_READY_TO_PREVIEW=list_id_here
TRELLO_LIST_READY_TO_PUBLISH=list_id_here
TRELLO_LIST_DONE=list_id_here

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token — needs repo + pull_requests scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_repo_name

# ── Anthropic ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
